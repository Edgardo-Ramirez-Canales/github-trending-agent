# Copia este archivo a .env y rellena los valores reales.
# Supabase: dashboard → Project Settings → API
VITE_SUPABASE_URL=https://xxxx.supabase.co
VITE_SUPABASE_ANON_KEY=sb_publishable_...

# Resend (resend.com) — SOLO se usa dentro de la Supabase Edge Function, no en el frontend.
RESEND_API_KEY=re_...

# NOTA: el GitHub Token y las claves de OpenAI/Gemini NO van aquí.
# Se ingresan en la UI y se guardan en localStorage. El token de GitHub se obtiene
# automáticamente del login OAuth (scope public_repo); el input manual es override.
